# =============================================================================
# FarsightIQ Attribute Manager - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
package-lock.json

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo
.vite/

# -----------------------------------------------------------------------------
# Environment files (NEVER commit real credentials)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# BUT keep templates for deployment teams
!.env.template
!.env.example

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.sublime-*
*.code-workspace

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
sqlnet.log

# -----------------------------------------------------------------------------
# Test outputs
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/
e2e-screenshots/

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.tscache/

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.db
*.sqlite3

# -----------------------------------------------------------------------------
# Temporary & Backup files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*~

# -----------------------------------------------------------------------------
# Archive (development artifacts)
# -----------------------------------------------------------------------------
archive/

# -----------------------------------------------------------------------------
# Internal docs & analysis (not for client delivery)
# -----------------------------------------------------------------------------
.internal-docs/
.musa/

# -----------------------------------------------------------------------------
# Oracle client (local development)
# -----------------------------------------------------------------------------
oracle-client/
instantclient*/


